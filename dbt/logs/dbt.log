  create table
    `default_catalog`.`clickstream`.`clickstream_summary`
  
  
    
    
  (
    event_type TEXT,
    session_id TEXT,
    product_id TEXT,
    event_count BIGINT,
    window_start TIMESTAMP(3),
    window_end TIMESTAMP(3)
    
    )

  
  as (
    
    select event_type, session_id, product_id, event_count, window_start, window_end
    from (
        with={
        'connector': 'clickhouse',
        'url': 'clickhouse://localhost:8123',
        'database-name': 'clickstream',
        'table-name': 'clickstream_analytics',
        'username': 'default',
        'password': 'clickhouse'
    }
) }}

SELECT 
    event_type,
    session_id,
    product_id,
    COUNT(*) as event_count,
    window_start,
    window_end
FROM TABLE(
    TUMBLE(TABLE `default_catalog`.`clickstream`.`clickstream_raw`, DESCRIPTOR(`timestamp`), INTERVAL '1' MINUTE))
GROUP BY event_type, session_id, product_id, window_start, window_end
    ) as model_subq
  );
  
